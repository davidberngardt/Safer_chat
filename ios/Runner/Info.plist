<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Основная информация о приложении -->
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>Safe Chat</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>safe_chat</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>
    
    <!-- Требования к iOS -->
    <key>LSRequiresIPhoneOS</key>
    <true/>
    
    <!-- Запуск и интерфейс -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
    <string>Main</string>
    
    <!-- Поддерживаемые ориентации для iPhone -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    
    <!-- Поддерживаемые ориентации для iPad -->
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    
    <!-- Производительность -->
    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>
    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>
    
    <!-- РАЗРЕШЕНИЯ И ОПИСАНИЯ (ОБЯЗАТЕЛЬНО ДЛЯ APP STORE) -->
    
    <!-- Камера -->
    <key>NSCameraUsageDescription</key>
    <string>Приложению нужен доступ к камере для видеозвонков, отправки фото и видео в чаты</string>
    
    <!-- Микрофон -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Приложению нужен доступ к микрофону для аудиозвонков и отправки голосовых сообщений</string>
    
    <!-- Фото библиотека (чтение) -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Приложению нужен доступ к галерее для отправки фото и видео в чаты</string>
    
    <!-- Фото библиотека (запись) -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Приложению нужен доступ для сохранения полученных фото и видео</string>
    
    <!-- Доступ к файлам -->
    <key>NSFileProviderPresenceUsageDescription</key>
    <string>Приложению нужен доступ к файлам для их отправки в чаты</string>
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>
    <key>UIFileSharingEnabled</key>
    <true/>
    
    <!-- Локальная сеть (для WebRTC) -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Приложению нужен доступ к локальной сети для установки прямых соединений при звонках</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_janus._udp</string>
        <string>_janus._tcp</string>
    </array>
    
    <!-- Фоновые режимы (для звонков и уведомлений) -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>voip</string>
        <string>fetch</string>
        <string>remote-notification</string>
        <string>processing</string>
    </array>
    
    <!-- Схемы URL для открытия внешних приложений -->
    <key>LSApplicationQueriesSchemes</key>
    <array>
        <!-- Веб-схемы -->
        <string>https</string>
        <string>http</string>
        
        <!-- Системные схемы -->
        <string>tel</string>
        <string>telprompt</string>
        <string>mailto</string>
        <string>sms</string>
        <string>facetime</string>
        <string>facetime-audio</string>
        
        <!-- Мессенджеры -->
        <string>whatsapp</string>
        <string>tg</string>
        <string>telegram</string>
        <string>viber</string>
        <string>skype</string>
        <string>zoom</string>
        <string>slack</string>
        
        <!-- Социальные сети -->
        <string>fb</string>
        <string>instagram</string>
        <string>twitter</string>
        <string>vkontakte</string>
        
        <!-- Карты и навигация -->
        <string>maps</string>
        <string>comgooglemaps</string>
        <string>yandexmaps</string>
        <string>yandextaxi</string>
    </array>
    
    <!-- Настройки безопасности транспорта (для HTTP в разработке) -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
        <key>NSAllowsArbitraryLoadsForMedia</key>
        <true/>
        <key>NSAllowsArbitraryLoadsInWebContent</key>
        <true/>
    </dict>
    
    <!-- Push-уведомления (APNs) -->
    <key>FirebaseAppDelegateProxyEnabled</key>
    <false/>
    
    <!-- VoIP и PushKit -->
    <key>PushKit</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
    
    <!-- Настройки для работы с VoIP -->
    <key>UIApplicationUsesBackgroundModeForVoIP</key>
    <true/>
    
    <!-- Версия iOS и требования -->
    <key>MinimumOSVersion</key>
    <string>12.0</string>
    
    <!-- Настройки для работы с Bluetooth гарнитурами -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Приложению нужен доступ к Bluetooth для подключения гарнитур во время звонков</string>
    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>Приложению нужен доступ к Bluetooth для подключения гарнитур</string>
    
    <!-- Настройки для работы с уведомлениями в фоне -->
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>$(PRODUCT_BUNDLE_IDENTIFIER).refresh</string>
        <string>$(PRODUCT_BUNDLE_IDENTIFIER).processing</string>
    </array>
    
    <!-- Получение удаленных уведомлений -->
    <key>UIBackgroundRefreshStatus</key>
    <string>enabled</string>
</dict>
</plist>